# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Override files as long as they're explicitly in .gitignore
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

.env.runtime
backend/_env.runtime
*.env.*
**._env.*
*.pptx
*.png
*.doc
*.docx
*.xls